{
  "name": "@cesium/utils",
  "version": "1.0.0",
  "type": "module",
  "main": "Build/index.cjs",
  "module": "Build/index.js",
  "types": "Build/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./Build/types/index.d.ts",
      "import": "./Build/index.js",
      "require": "./Build/index.cjs"
    },
    "./*": "./*"
  },
  "files": [
    "Build"
  ],
  "scripts": {
    "buildTsTypes": "tsc -p tsconfig.types.json",
    "buildSpecs": "tsc -p tsconfig.specs.json",
    "build": "vite build && npm run buildTsTypes && npm run buildSpecs"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.2",
    "typescript": "^5.8.2",
    "vite": "^6.2.6"
  }
}
